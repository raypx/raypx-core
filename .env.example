# -----------------------------------------------------------------------------
# Web Information
# -----------------------------------------------------------------------------
NEXT_PUBLIC_WEB_URL = "http://localhost:3000"
NEXT_PUBLIC_PROJECT_NAME = "Raypx"

# -----------------------------------------------------------------------------
# Database with Supabase
# -----------------------------------------------------------------------------
# https://supabase.com/docs/guides/getting-started/quickstarts/nextjs
# Set your Supabase URL and Anon Key
DATABASE_URL = ""

# -----------------------------------------------------------------------------
# Redis with Upstash
# -----------------------------------------------------------------------------
# https://upstash.com/docs/redis/overall/getstarted
# Set your Upstash URL and Token
REDIS_URL = ""

# -----------------------------------------------------------------------------
# Auth with next-auth
# https://authjs.dev/getting-started/installation?framework=Next.js
# Set your Auth URL and Secret
# Secret can be generated with `openssl rand -base64 32`
# -----------------------------------------------------------------------------
AUTH_SECRET = ""

# Google Auth
# https://authjs.dev/getting-started/providers/google
AUTH_GOOGLE_ID = ""
AUTH_GOOGLE_SECRET = ""
NEXT_PUBLIC_AUTH_GOOGLE_ID = ""
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED = "false"
NEXT_PUBLIC_AUTH_GOOGLE_ONE_TAP_ENABLED = "false"

# Github Auth
# https://authjs.dev/getting-started/providers/github
AUTH_GITHUB_ID = ""
AUTH_GITHUB_SECRET = ""
NEXT_PUBLIC_AUTH_GITHUB_ENABLED = "false"

# Resend
RESEND_FROM = ""
AUTH_RESEND_KEY = ""

# -----------------------------------------------------------------------------
# Analytics Configuration
# https://docs.raypx.com/analytics-setup
# -----------------------------------------------------------------------------

# PostHog Analytics (Recommended for AI platforms)
# Get your key from: https://app.posthog.com/project/settings
NEXT_PUBLIC_POSTHOG_KEY = ""
NEXT_PUBLIC_POSTHOG_HOST = "https://app.posthog.com"
NEXT_PUBLIC_POSTHOG_INGESTION_URL = "https://app.posthog.com"

# Google Analytics (Optional)
# Get your ID from: https://analytics.google.com
NEXT_PUBLIC_GA_MEASUREMENT_ID = ""

# Umami Analytics (Optional - Privacy-friendly alternative)
# Self-hosted analytics: https://umami.is
NEXT_PUBLIC_UMAMI_HOST = ""
NEXT_PUBLIC_UMAMI_WEBSITE_ID = ""

# Analytics Control
NEXT_PUBLIC_ANALYTICS_DISABLED = "false"
NEXT_PUBLIC_ANALYTICS_DEBUG = "false"

# Legacy Analytics (Deprecated - use PostHog instead)
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID = ""
NEXT_PUBLIC_OPENPANEL_CLIENT_ID = ""

# -----------------------------------------------------------------------------
# Payment with Stripe
# https://docs.stripe.com/keys
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY = ""
STRIPE_PRIVATE_KEY = ""
STRIPE_WEBHOOK_SECRET = ""

NEXT_PUBLIC_PAY_SUCCESS_URL = "http://localhost:3000/my-orders"
NEXT_PUBLIC_PAY_FAIL_URL = "http://localhost:3000/#pricing"
NEXT_PUBLIC_PAY_CANCEL_URL = "http://localhost:3000/#pricing"

NEXT_PUBLIC_LOCALE_DETECTION = "false"

ADMIN_EMAILS = ""

NEXT_PUBLIC_DEFAULT_THEME = "light"

# ---
# OPENAI
